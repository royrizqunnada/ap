# Salin file ini menjadi .env lalu isi nilainya.
#   cp .env.example .env

# WAJIB: kunci API asli dari https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opsional: model Claude yang dipakai (default: claude-opus-4-8)
# Bisa pakai CLAUDE_MODEL atau ANTHROPIC_MODEL.
# CLAUDE_MODEL=claude-opus-4-8

# Opsional: port server (default: 3000)
# PORT=3000

# Opsional: instruksi sistem untuk asisten
# SYSTEM_PROMPT=Anda adalah asisten yang ramah dan membantu.
